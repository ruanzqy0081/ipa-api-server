{
        "version": 2,
        "buildCommand": "npm run build",
        "outputDirectory": "dist/public",
        "functions": {
                  "server/_core/index.ts": {
                              "runtime": "nodejs20.x",
                              "memory": 1024,
                              "maxDuration": 60
                  }
        },
        "routes": [
                  { "src": "/api/(.*)", "dest": "/server/_core/index.ts", "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"] },
                  { "src": "/(.*)", "dest": "/index.html", "status": 200 }
        ]
}
