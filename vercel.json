{
              "version": 2,
              "buildCommand": "npm run build",
              "outputDirectory": "client/dist",
              "functions": {
                              "server/_core/index.ts": {
                                                "runtime": "nodejs20.x"
                              }
              },
              "rewrites": [
                              { "source": "/api/(.*)", "destination": "/server/_core/index.ts" },
                              { "source": "/(.*)", "destination": "/index.html" }
              ]
}
